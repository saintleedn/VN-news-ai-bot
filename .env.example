# Anthropic Claude API Key
# Lấy tại: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram Bot Token
# Tạo bot qua @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID kênh Telegram đăng tin
# Có thể dùng @username (VD: @mynewschannel) hoặc numeric ID (VD: -1001234567890)
# Bot phải là Admin của kênh với quyền "Post Messages"
TELEGRAM_CHANNEL_ID=@your_channel_username

# Chat ID của admin để nhận báo cáo
# Lấy bằng cách nhắn tin @userinfobot hoặc xem API getUpdates
TELEGRAM_ADMIN_CHAT_ID=123456789
